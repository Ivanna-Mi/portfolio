# .env.local.example
# Copy this to .env.local — do NOT commit .env.local to git

# GitHub Personal Access Token (optional)
# Increases API rate limit from 60/hr to 5000/hr
# Only needs "public_repo" read scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Email provider (optional, for contact form)
# Uncomment and fill when you wire up an email provider
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Dashboard auth (optional — for production)
# DASHBOARD_PASSWORD=your-secret-password
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3000
